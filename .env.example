# Veritabanı bağlantısı
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=insyte;Username=postgres;Password=changeme

# JWT yapılandırması
Jwt__Key=your-super-secret-jwt-key-at-least-32-characters-long
Jwt__Issuer=insyte-api
Jwt__Audience=insyte-client
Jwt__AccessTokenExpirationMinutes=15
Jwt__RefreshTokenExpirationDays=30

# Dosya depolama (S3/MinIO)
Storage__Provider=S3
Storage__Bucket=insyte-videos
Storage__AccessKey=your-access-key
Storage__SecretKey=your-secret-key
Storage__Endpoint=https://s3.amazonaws.com

# E-posta
Smtp__Host=smtp.sendgrid.net
Smtp__Port=587
Smtp__Username=apikey
Smtp__Password=your-smtp-password
Smtp__FromEmail=noreply@insyte.com
Smtp__FromName=Insyte Platform

# NOT: AI API anahtarları veritabanında şifreli tutulur, burada olmaz
